{
  "info": {
    "name": "CryptoDashboard API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5052",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Cryptocurrencies",
      "item": [
        {
          "name": "Refresh coins (auth required)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/cryptocurrencies/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cryptocurrencies", "refresh"]
            }
          }
        },
        {
          "name": "List coins",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/cryptocurrencies?page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cryptocurrencies"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get coin by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/cryptocurrencies/bitcoin",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cryptocurrencies", "bitcoin"]
            }
          }
        },
        {
          "name": "Get coin price history",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/cryptocurrencies/bitcoin/history?days=7",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cryptocurrencies", "bitcoin", "history"],
              "query": [
                { "key": "days", "value": "7", "description": "Allowed: 1, 7, 14, 30, 90, 180, 365" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Watchlist",
      "item": [
        {
          "name": "Add to watchlist",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/watchlist",
              "host": ["{{baseUrl}}"],
              "path": ["api", "watchlist"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cryptocurrencyId\": \"bitcoin\"\n}"
            }
          }
        },
        {
          "name": "Get watchlist",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/watchlist",
              "host": ["{{baseUrl}}"],
              "path": ["api", "watchlist"]
            }
          }
        }
      ]
    }
  ]
}
